resource_name = "GameRoot"
script/source = "extends Node

var task_list = {
	0: \"task_string1\"
}

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	# TODO - call based on a signal from UI?
	update_task_list()
	$UI.todo_opened.connect(update_task_list)
	$World.start_game()
	
	EventBus.task_completed.connect(_on_task_completed)

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass

func update_task_list():
	$UI.update_task_list(task_list)

func _on_task_completed(task_id):
	GameState.task_completion[task_id] = true
"

[sub_resource type="GDScript" id="GDScript_wnm2b"]
resource_name = "World"
script/source = "extends Node2D

var character_prefab = preload(\"res://scenes/player/player_character.tscn\")
var mini_game_0_prefab = preload(\"res://scenes/mini_games/mini_game_0.tscn\") 
var mini_game_1_prefab = preload(\"res://scenes/mini_games/mini_game_1.tscn\")
var mini_game_8_prefab = preload(\"res://scenes/mini_games/mini_game_8.tscn\")
var active_room: Node2D
@onready var transition: ColorRect = $\"../UI/ColorRect\"

func start_game():
	change_room(-1, 0)
	
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass

func fade_to_black():
	var tween: Tween = create_tween()
	tween.tween_property(transition, \"modulate:a\", 0.0, 0.5).from(1.0)
	await tween.finished

func change_room(door_source: int, room_id: int):
	if active_room:
		active_room.queue_free()
	active_room = Factory.create_room(room_id, door_source)
	active_room.room_changed.connect(change_room)
	fade_to_black()
	active_room.character.on_interact.connect(on_interact)
	call_deferred(\"add_child\", active_room)

func on_interact():
	if active_room.interactible == -1:
		return
	elif active_room.interactible == 0:
		EventBus.display_dialog.emit(\"potato_string1\")
		var mini_game_0 = mini_game_0_prefab.instantiate()
		add_child(mini_game_0)
		mini_game_0.completed.connect(
			func():
				remove_child(mini_game_0)
				EventBus.task_completed.emit(0)
		)
	elif active_room.interactible == 1:
		EventBus.task_completed.emit(1)

	elif active_room.interactible == 2:
		EventBus.queue_dialog.emit(\"minigame1_string1\")
		while GameState.checked_mirror < 2:
			var mini_game_1 = mini_game_1_prefab.instantiate()
			add_child(mini_game_1)
			mini_game_1.completed.connect(
				func():
					remove_child(mini_game_1)
					EventBus.task_completed.emit(2)
		)
			GameState.checked_mirror += 1
		if GameState.checked_mirror == 2:
			print(\"we have looked at ourselves 3 times now!\")
			# TODO = add easter egg logic 
	elif active_room.interactible == 8:
		var mini_game_8 = mini_game_8_prefab.instantiate()
		add_child(mini_game_8)
		mini_game_8.completed.connect(
			func():
				remove_child(mini_game_8)
				change_room(-1, 9)
		)
	print(\"interacting with %s\" % active_room.interactible)
	# TODO - launch interactible minigame based on the contents of active_room.interactible
	
	
"

[sub_resource type="GDScript" id="GDScript_rckx3"]
resource_name = "UI"
script/source = "extends Control
signal todo_opened

var todo_item_obj = preload(\"res://scenes/todo/todo-item.tscn\")

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass

func update_task_list(task_list):
	var index = 0
	for child in $Todo/List.get_children():
		child.queue_free()
	for task in task_list:
		var task_item = todo_item_obj.instantiate()
		if GameState.task_completion[index]:
			task_item.text = \"[s]%s[/s]\" % tr(task_list[task])
		else:
			task_item.text = task_list[task]
		$Todo/List.add_child(task_item)
		index += 1


func _input(event):
	if GameState.in_mini_game:
		return
	if event.is_action_pressed(\"todo\"):
		$Todo.change_state()
		todo_opened.emit()
"

