[sub_resource type="GDScript" id="GDScript_ab2as"]
resource_name = "Door0"
script/source = "extends Area2D
signal door_entered

var door_id: int = -1
var enabled = true

func _body_entered(body: Node2D) -> void:
	if enabled:
		door_entered.emit(door_id)


func _on_body_exited(body: Node2D) -> void:
	print(\"exit\")
	enabled = true
"

